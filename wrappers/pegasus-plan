#!/usr/bin/env python3
"""
pegasus-plan wrapper — adds runtime prediction jobs to the concrete DAG.

The abstract workflow (workflow.yml) is NEVER modified.
After pegasus-plan generates the .dag file, this wrapper injects
ONE pegasus-runtime-predictor job per DAG level — same pattern as
how Pegasus adds stage-in/cleanup to the concrete planned workflow.

DAG shape (concrete, after injection):
    [pred-L0] → [L0 user jobs]
                       ↓
                 [pred-L1] → [L1 user jobs]
                                    ↓
                              [pred-L2] → [L2 user jobs]
"""
import os
import re
import sys
import subprocess
from pathlib import Path

# ── Package path setup ────────────────────────────────────────────────────────
_SRC_DIR = Path(__file__).resolve().parent.parent   # pegasus-wms-runtime-src/
for _pkg in ("pegasus-api", "pegasus-common", "pegasus-python", "pegasus-worker"):
    _p = _SRC_DIR / "packages" / _pkg / "src"
    if _p.exists():
        sys.path.insert(0, str(_p))

_PREDICTOR = str(_SRC_DIR / "bin" / "pegasus-runtime-predictor")


# ── Helpers ───────────────────────────────────────────────────────────────────

def _real_pegasus_plan() -> str:
    pegasus_home = os.environ.get("PEGASUS_HOME")
    if pegasus_home:
        real = Path(pegasus_home) / "bin" / "pegasus-plan"
        if real.exists():
            return str(real)
    this_bin = str(Path(__file__).parent)
    for d in os.environ.get("PATH", "").split(":"):
        if d == this_bin:
            continue
        candidate = Path(d) / "pegasus-plan"
        if candidate.exists():
            return str(candidate)
    raise FileNotFoundError("Cannot find real pegasus-plan. Set PEGASUS_HOME.")


def _find_dag_file(plan_output: str) -> str | None:
    """Parse pegasus-plan stdout/stderr to locate the generated .dag file."""
    # Best match: line with the full absolute path
    m = re.search(
        r'Successfully checked generated dag for correctness\s+(\S+\.dag)',
        plan_output,
    )
    if m and Path(m.group(1)).exists():
        return m.group(1)

    # Fallback: relative path from submit line
    m = re.search(
        r'File for submitting this DAG to HTCondor\s*:\s*(\S+\.dag\.condor\.sub)',
        plan_output,
    )
    if m:
        dag = m.group(1).replace(".dag.condor.sub", ".dag")
        if Path(dag).exists():
            return dag
    return None


def _find_workflow_yaml(args) -> str | None:
    for arg in args:
        if (arg.endswith(".yml") or arg.endswith(".yaml")) and Path(arg).exists():
            return arg
    return None


def _parse_dag_levels(dag_text: str):
    """
    Topological sort of JOB nodes in a .dag file into levels.
    Skips Pegasus-generated infrastructure jobs (stage-in, cleanup, create-dir).
    """
    jobs = {}       # job_id -> sub_file
    children = {}   # parent_id -> set of child_ids

    for line in dag_text.splitlines():
        line = line.strip()
        if line.startswith("JOB "):
            parts = line.split()
            jobs[parts[1]] = parts[2] if len(parts) > 2 else ""
        elif line.startswith("PARENT "):
            parts = line.split()
            child_start = parts.index("CHILD")
            parents = parts[1:child_start]
            childs  = parts[child_start + 1:]
            for p in parents:
                children.setdefault(p, set()).update(childs)

    # Skip Pegasus internal jobs (they contain "stage", "clean", "create_dir")
    skip = {j for j in jobs if re.search(r"stage_|cleanup|create_dir|chmod", j, re.I)}
    user_jobs = {j: s for j, s in jobs.items() if j not in skip}

    # Build parent map for user jobs only
    parent_map = {j: set() for j in user_jobs}
    for p, cs in children.items():
        for c in cs:
            if c in user_jobs and p in user_jobs:
                parent_map[c].add(p)

    # Kahn's topological sort
    levels, assigned, remaining = [], set(), set(user_jobs)
    while remaining:
        level = [j for j in remaining if parent_map.get(j, set()).issubset(assigned)]
        if not level:
            level = list(remaining)
        levels.append(level)
        assigned.update(level)
        remaining -= set(level)

    return levels


def _job_subdir(dag_dir: Path) -> Path:
    """
    Return the submit-file subdirectory Pegasus uses (e.g. run00XX/00/00/).
    Falls back to dag_dir itself if no subdirectory structure is found.
    """
    # Pegasus creates numeric two-level dirs: 00/00, 00/01, ...
    for d1 in sorted(dag_dir.iterdir()):
        if d1.is_dir() and d1.name.isdigit():
            for d2 in sorted(d1.iterdir()):
                if d2.is_dir() and d2.name.isdigit():
                    return d2
    return dag_dir


def _create_pred_sub(dag_dir: Path, job_id: str, wf_yaml: str,
                     output_dir: str, level_idx: int) -> str:
    """Write an HTCondor submit file for a prediction job."""
    sub_dir = _job_subdir(dag_dir)
    sub_dir.mkdir(parents=True, exist_ok=True)
    sub = sub_dir / f"{job_id}.sub"
    log = sub_dir / f"{job_id}.log"
    out = sub_dir / f"{job_id}.out"
    err = sub_dir / f"{job_id}.err"
    sub.write_text(
        f"universe       = local\n"
        f"executable     = {sys.executable}\n"
        f"arguments      = {_PREDICTOR} {wf_yaml} {output_dir} --level={level_idx}\n"
        f"log            = {log}\n"
        f"output         = {out}\n"
        f"error          = {err}\n"
        f"should_transfer_files = NO\n"
        f"+pegasus_job_type = \"auxillary\"\n"
        f"+pegasus_wf_xformation = \"pegasus::runtime-predictor\"\n"
        f"queue\n"
    )
    return str(sub)


def _patch_dot_file(dag_dir: Path, levels: list, all_job_ids: set):
    """
    Add prediction job nodes and edges to the concrete .dot file so they
    appear in the Graphviz visualization alongside stage-in/cleanup jobs.
    """
    dot_files = list(dag_dir.glob("*.dot"))
    if not dot_files:
        return
    dot_path = dot_files[0]
    dot_text = dot_path.read_text()

    # Insert before the closing brace of the digraph
    insert_lines = ["\n  // Runtime Prediction Jobs"]
    prev_level_jobs = None

    for lvl_idx, level_jobs in enumerate(levels):
        pred_id = f"pegasus_runtime_pred_L{lvl_idx}"
        # Node styled like Pegasus auxiliary jobs (blue, filled)
        insert_lines.append(
            f'  "{pred_id}" [label="runtime-predictor\\nL{lvl_idx}",'
            f' shape=ellipse, style=filled, fillcolor=lightblue,'
            f' color=blue, fontsize=10];'
        )
        # pred → user jobs at this level
        for jid in level_jobs:
            if jid in all_job_ids:
                insert_lines.append(f'  "{pred_id}" -> "{jid}";')
        # previous level user jobs → pred
        if prev_level_jobs:
            for jid in prev_level_jobs:
                if jid in all_job_ids:
                    insert_lines.append(f'  "{jid}" -> "{pred_id}";')
        prev_level_jobs = level_jobs

    new_dot = dot_text.rstrip()
    if new_dot.endswith("}"):
        new_dot = new_dot[:-1] + "\n".join(insert_lines) + "\n}\n"
        dot_path.write_text(new_dot)


def _inject_prediction_jobs(dag_path: str, wf_yaml: str, output_dir: str):
    """
    Append pegasus-runtime-predictor jobs to the concrete .dag file.
    One job per user-job level, wired exactly like stage-in/cleanup nodes.
    Also patches the .dot visualization file so jobs appear in Graphviz.
    """
    with open(dag_path) as f:
        dag_text = f.read()

    # Skip if already injected
    if "pegasus_runtime_pred_" in dag_text:
        print("[pegasus-plan] Prediction jobs already in DAG — skipping.", flush=True)
        return

    dag_dir = Path(dag_path).parent
    levels  = _parse_dag_levels(dag_text)
    if not levels:
        return

    # All user job IDs for dot patching
    all_job_ids = {jid for level in levels for jid in level}

    job_lines = []
    dep_lines = []
    prev_level_jobs = None

    for lvl_idx, level_jobs in enumerate(levels):
        pred_id  = f"pegasus_runtime_pred_L{lvl_idx}"
        # Output goes inside the run directory alongside other Pegasus artifacts
        sub_file = _create_pred_sub(dag_dir, pred_id, wf_yaml, output_dir, lvl_idx)

        job_lines.append(f"JOB {pred_id} {sub_file}")

        # pred-LN runs before every user job at level N
        for jid in level_jobs:
            dep_lines.append(f"PARENT {pred_id} CHILD {jid}")

        # pred-LN waits for ALL user jobs at level N-1 to finish
        if prev_level_jobs:
            for jid in prev_level_jobs:
                dep_lines.append(f"PARENT {jid} CHILD {pred_id}")

        prev_level_jobs = level_jobs

    with open(dag_path, "a") as f:
        f.write("\n# ── Runtime Prediction Jobs (injected by pegasus-plan wrapper) ──\n")
        for line in job_lines:
            f.write(line + "\n")
        for line in dep_lines:
            f.write(line + "\n")

    # Patch the Graphviz .dot file so prediction jobs are visible
    _patch_dot_file(dag_dir, levels, all_job_ids)

    print(
        f"[pegasus-plan] Injected {len(levels)} runtime prediction job(s) into DAG.",
        flush=True,
    )


# ── Main ──────────────────────────────────────────────────────────────────────

args    = sys.argv[1:]
wf_yaml = _find_workflow_yaml(args)
real    = _real_pegasus_plan()

# Run real pegasus-plan, capturing output so we can find the .dag path
result  = subprocess.run(
    [real] + args,
    stdout=subprocess.PIPE,
    stderr=subprocess.STDOUT,
    text=True,
)

# Stream output to user
print(result.stdout, end="", flush=True)

if result.returncode == 0 and wf_yaml:
    dag_path = _find_dag_file(result.stdout)
    if dag_path:
        # Output lives inside the run directory, next to other Pegasus artifacts
        output_dir = str(Path(dag_path).parent)
        _inject_prediction_jobs(dag_path, wf_yaml, output_dir)
    else:
        print("[pegasus-plan] Could not locate .dag file — prediction not injected.", flush=True)

sys.exit(result.returncode)
