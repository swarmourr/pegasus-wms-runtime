#!/usr/bin/env python3
"""
pegasus-runtime-predictor — thin launcher for source / editable installs.

When installed via pip the console_scripts entry point
(Pegasus.cli.pegasus_runtime_predictor:_run) is used directly.

This file exists so that source checkouts (where the packages are not
yet on sys.path) still work: it injects the package paths then delegates
to the canonical implementation in the installed package.
"""
import sys
from pathlib import Path

# ── Path setup (source/editable installs only) ────────────────────────────────
# When the packages are already installed (pip install -e or pip install),
# these paths won't exist and the loop is a no-op — installed packages are
# used automatically.
_BIN_DIR = Path(__file__).resolve().parent
_SRC_DIR = _BIN_DIR.parent  # pegasus-wms-runtime-src/
for _pkg in ("pegasus-api", "pegasus-common", "pegasus-python", "pegasus-worker"):
    _p = _SRC_DIR / "packages" / _pkg / "src"
    if _p.exists():
        sys.path.insert(0, str(_p))

# ── Delegate to the package module ────────────────────────────────────────────
from Pegasus.cli.pegasus_runtime_predictor import _run  # noqa: E402

if __name__ == "__main__":
    _run()
