#!/usr/bin/env python3
"""
pegasus-plan wrapper — injects runtime prediction jobs before planning.

The user's workflow.yml is NEVER modified. The wrapper:
  1. Reads workflow.yml
  2. Topologically sorts jobs into levels
  3. Adds one pegasus-runtime-predictor job per level + TC entry
     into a TEMP copy of the workflow
  4. Calls real pegasus-plan with the temp file
  5. Deletes the temp file

The Java planner then handles .sub creation, DB registration,
pegasus-status tracking, and Graphviz visualization — exactly
the same as it does for stage-in/cleanup/dirmanager jobs.

DAG shape after planning:
    [pred-L0] → [L0 user jobs] → [pred-L1] → [L1 user jobs] → ...
"""
import os
import re
import sys
import subprocess
import tempfile
from pathlib import Path

try:
    import yaml
except ImportError:
    yaml = None

# ── Package path setup ────────────────────────────────────────────────────────
_SRC_DIR = Path(__file__).resolve().parent.parent   # pegasus-wms-runtime-src/
for _pkg in ("pegasus-api", "pegasus-common", "pegasus-python", "pegasus-worker"):
    _p = _SRC_DIR / "packages" / _pkg / "src"
    if _p.exists():
        sys.path.insert(0, str(_p))

_PREDICTOR = str(_SRC_DIR / "bin" / "pegasus-runtime-predictor")


# ── Helpers ───────────────────────────────────────────────────────────────────

def _real_pegasus_plan() -> str:
    pegasus_home = os.environ.get("PEGASUS_HOME")
    if pegasus_home:
        real = Path(pegasus_home) / "bin" / "pegasus-plan"
        if real.exists():
            return str(real)
    this_bin = str(Path(__file__).parent)
    for d in os.environ.get("PATH", "").split(":"):
        if d == this_bin:
            continue
        candidate = Path(d) / "pegasus-plan"
        if candidate.exists():
            return str(candidate)
    raise FileNotFoundError("Cannot find real pegasus-plan. Set PEGASUS_HOME.")


def _find_workflow_yaml(args) -> str | None:
    for arg in args:
        if (arg.endswith(".yml") or arg.endswith(".yaml")) and Path(arg).exists():
            return arg
    return None


def _topo_levels(jobs: list, deps: list) -> list:
    """
    Topological sort of workflow jobs into levels.
    Returns list of levels; each level is a list of job IDs.
    Skips Pegasus auxiliary jobs (pegasus-runtime-predictor).
    """
    # Build id → job map
    job_ids = {j["id"] for j in jobs
               if j.get("name", "") != "pegasus-runtime-predictor"}

    # parent → children map from dependencies
    children_map = {}  # parent_id → [child_id, ...]
    for dep in (deps or []):
        pid = dep.get("id")
        for cid in dep.get("children", []):
            children_map.setdefault(pid, []).append(cid)

    # Build parent map for user jobs only
    parent_map = {jid: set() for jid in job_ids}
    for pid, cids in children_map.items():
        for cid in cids:
            if cid in job_ids and pid in job_ids:
                parent_map[cid].add(pid)

    levels, assigned, remaining = [], set(), set(job_ids)
    while remaining:
        level = [j for j in remaining if parent_map.get(j, set()).issubset(assigned)]
        if not level:
            level = list(remaining)
        levels.append(level)
        assigned.update(level)
        remaining -= set(level)
    return levels


def _build_temp_workflow(wf_yaml: str) -> str | None:
    """
    Read workflow.yml, inject prediction jobs and TC entry,
    write to a temp file beside the original. Returns temp file path.
    Returns None if injection is not possible (no yaml module, etc).
    """
    if yaml is None:
        return None

    with open(wf_yaml) as f:
        wf = yaml.safe_load(f)

    jobs  = wf.get("jobs", [])
    deps  = wf.get("dependencies", [])
    levels = _topo_levels(jobs, deps)
    if not levels:
        return None

    output_dir = str(Path(wf_yaml).resolve().parent / "output")

    # ── Build dependency map for merging ──────────────────────────────────
    # dep_map: job_id → set of children (mutable, will be serialised back)
    dep_map = {}
    for dep in deps:
        pid = dep.get("id")
        dep_map[pid] = set(dep.get("children", []))

    new_jobs = []

    for lvl_idx, level_job_ids in enumerate(levels):
        pred_id = f"pegasus_runtime_pred_L{lvl_idx}"

        new_jobs.append({
            "type": "job",
            "name": "pegasus-runtime-predictor",
            "id":   pred_id,
            "arguments": [
                str(Path(wf_yaml).resolve()),
                output_dir,
                f"--level={lvl_idx}",
            ],
            "uses": [],
            "profiles": {
                "pegasus": {
                    "job.type": "auxillary",
                    "label":    f"runtime-prediction-L{lvl_idx}",
                },
                "condor": {
                    "universe": "local",
                },
            },
        })

        # pred-LN → user jobs at level N
        dep_map.setdefault(pred_id, set()).update(level_job_ids)

        # user jobs at level N-1 → pred-LN  (so pred-LN waits for real data)
        if lvl_idx > 0:
            for pjid in levels[lvl_idx - 1]:
                dep_map.setdefault(pjid, set()).add(pred_id)

    # Serialise dep_map back to list-of-dicts
    new_deps = [{"id": pid, "children": sorted(cids)}
                for pid, cids in dep_map.items() if cids]

    wf["jobs"] = jobs + new_jobs
    wf["dependencies"] = new_deps

    # ── Add TC entry for pegasus-runtime-predictor ────────────────────────
    tc = wf.get("transformationCatalog", {})
    transforms = tc.get("transformations", [])
    # Only add if not already present
    existing_names = {t.get("name") for t in transforms}
    if "pegasus-runtime-predictor" not in existing_names:
        transforms.append({
            "name": "pegasus-runtime-predictor",
            "sites": [
                {
                    "name": "local",
                    "pfn":  _PREDICTOR,
                    "type": "installed",
                },
                {
                    "name": "condorpool",
                    "pfn":  _PREDICTOR,
                    "type": "installed",
                },
            ],
        })
    tc["transformations"] = transforms
    wf["transformationCatalog"] = tc

    # Write temp file next to original — absolute path, no leading dot
    orig = Path(wf_yaml).resolve()
    tmp_path = orig.parent / f"_pred_{orig.name}"
    with open(tmp_path, "w") as f:
        yaml.dump(wf, f, default_flow_style=False, sort_keys=False)

    return str(tmp_path)


# ── Main ──────────────────────────────────────────────────────────────────────

args    = sys.argv[1:]
wf_yaml = _find_workflow_yaml(args)
real    = _real_pegasus_plan()

tmp_wf = None
plan_args = list(args)

if wf_yaml:
    tmp_wf = _build_temp_workflow(wf_yaml)
    if tmp_wf:
        # Replace original workflow path with absolute temp path in args
        wf_abs = str(Path(wf_yaml).resolve())
        plan_args = [tmp_wf if (a == wf_yaml or a == wf_abs) else a for a in args]
        print(f"[pegasus-plan] Injected prediction jobs into temp workflow for planning.",
              flush=True)
    else:
        print("[pegasus-plan] Could not build temp workflow — planning without prediction jobs.",
              flush=True)

# Run real pegasus-plan (streams output directly — no capture needed)
result = subprocess.run([real] + plan_args)

# Clean up temp file
if tmp_wf and Path(tmp_wf).exists():
    Path(tmp_wf).unlink()

sys.exit(result.returncode)
