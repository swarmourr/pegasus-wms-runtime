#!/usr/bin/env python3
"""
pegasus-plan wrapper — injects runtime prediction jobs before planning.

The user's workflow.yml is NEVER modified. The wrapper:
  1. Reads workflow.yml
  2. Topologically sorts jobs into levels
  3. Adds one pegasus-runtime-predictor job per level + TC entry
     into a TEMP copy of the workflow
  4. Calls real pegasus-plan with the temp file
  5. Deletes the temp file

The Java planner then handles .sub creation, DB registration,
pegasus-status tracking, and Graphviz visualization — exactly
the same as it does for stage-in/cleanup/dirmanager jobs.

DAG shape after planning:
    [pred-L0] → [L0 user jobs] → [pred-L1] → [L1 user jobs] → ...
"""
import os
import re
import sys
import subprocess
import tempfile
from pathlib import Path

try:
    import yaml
except ImportError:
    yaml = None

# ── Package path setup ────────────────────────────────────────────────────────
_SRC_DIR = Path(__file__).resolve().parent.parent   # pegasus-wms-runtime-src/
for _pkg in ("pegasus-api", "pegasus-common", "pegasus-python", "pegasus-worker"):
    _p = _SRC_DIR / "packages" / _pkg / "src"
    if _p.exists():
        sys.path.insert(0, str(_p))

_PREDICTOR = str(_SRC_DIR / "bin" / "pegasus-runtime-predictor")


# ── Helpers ───────────────────────────────────────────────────────────────────

def _real_pegasus_plan() -> str:
    pegasus_home = os.environ.get("PEGASUS_HOME")
    if pegasus_home:
        real = Path(pegasus_home) / "bin" / "pegasus-plan"
        if real.exists():
            return str(real)
    this_bin = str(Path(__file__).parent)
    for d in os.environ.get("PATH", "").split(":"):
        if d == this_bin:
            continue
        candidate = Path(d) / "pegasus-plan"
        if candidate.exists():
            return str(candidate)
    raise FileNotFoundError("Cannot find real pegasus-plan. Set PEGASUS_HOME.")


def _find_workflow_yaml(args) -> str | None:
    for arg in args:
        if (arg.endswith(".yml") or arg.endswith(".yaml")) and Path(arg).exists():
            return arg
    return None


def _topo_levels(jobs: list, deps: list) -> list:
    """
    Topological sort of workflow jobs into levels.
    Returns list of levels; each level is a list of job IDs.
    Skips Pegasus auxiliary jobs (pegasus-runtime-predictor).
    """
    # Build id → job map
    job_ids = {j["id"] for j in jobs
               if j.get("name", "") != "pegasus-runtime-predictor"}

    # parent → children map from dependencies
    children_map = {}  # parent_id → [child_id, ...]
    for dep in (deps or []):
        pid = dep.get("id")
        for cid in dep.get("children", []):
            children_map.setdefault(pid, []).append(cid)

    # Build parent map for user jobs only
    parent_map = {jid: set() for jid in job_ids}
    for pid, cids in children_map.items():
        for cid in cids:
            if cid in job_ids and pid in job_ids:
                parent_map[cid].add(pid)

    levels, assigned, remaining = [], set(), set(job_ids)
    while remaining:
        level = [j for j in remaining if parent_map.get(j, set()).issubset(assigned)]
        if not level:
            level = list(remaining)
        levels.append(level)
        assigned.update(level)
        remaining -= set(level)
    return levels


_PRED_SITES = [
    {
        "name": "local",
        "pfn":  _PREDICTOR,
        "type": "installed",
    },
    {
        "name": "condorpool",
        "pfn":  _PREDICTOR,
        "type": "installed",
        "profiles": {
            "condor": {"universe": "local"},
        },
    },
]

_PRED_TC_ENTRY = {
    "name": "pegasus-runtime-predictor",
    "sites": _PRED_SITES,
}


def _write_standalone_tc(dest_dir: Path) -> str:
    """
    Write a standalone _pred_tc.yml that Pegasus can use as a TC source.
    Merges with any existing tc.yml or properties-configured TC file so
    user transformations are not lost.
    Returns absolute path to the file.
    """
    transforms = []

    # Collect candidate TC source files (highest priority last → overwrites)
    tc_candidates: list[Path] = []

    # 1. tc.yml beside the workflow
    for name in ("tc.yml", "tc.yaml"):
        p = dest_dir / name
        if p.exists():
            tc_candidates.append(p)
            break

    # 2. TC file specified in pegasus.properties
    prop_tc = _read_property("pegasus.catalog.transformation.file")
    if prop_tc:
        p = Path(prop_tc)
        if not p.is_absolute():
            p = dest_dir / prop_tc
        if p.exists():
            tc_candidates.append(p)

    for tc_path in tc_candidates:
        try:
            existing = yaml.safe_load(tc_path.read_text()) or {}
            for t in existing.get("transformations", []):
                if t.get("name") != "pegasus-runtime-predictor":
                    transforms.append(t)
        except Exception:
            pass

    transforms.append(_PRED_TC_ENTRY)

    tc_doc = {
        "pegasus": "5.0",
        "transformations": transforms,
    }
    out_path = dest_dir / "_pred_tc.yml"
    with open(out_path, "w") as f:
        yaml.dump(tc_doc, f, default_flow_style=False, sort_keys=False)
    return str(out_path)


def _build_temp_workflow(wf_yaml: str) -> tuple[str, str] | tuple[None, None]:
    """
    Read workflow.yml, inject prediction jobs and TC entry,
    write to a temp file beside the original.
    Returns (temp_workflow_path, temp_tc_path) or (None, None).
    """
    if yaml is None:
        return None, None

    with open(wf_yaml) as f:
        wf = yaml.safe_load(f)

    jobs  = wf.get("jobs", [])
    # Pegasus 5.x YAML uses "jobDependencies"; older versions use "dependencies"
    deps_key = "jobDependencies" if "jobDependencies" in wf else "dependencies"
    deps  = wf.get(deps_key, [])
    levels = _topo_levels(jobs, deps)
    if not levels:
        return None, None

    output_dir = str(Path(wf_yaml).resolve().parent / "output")

    # ── Build dependency map for merging ──────────────────────────────────
    dep_map = {}
    for dep in deps:
        pid = dep.get("id")
        dep_map[pid] = set(dep.get("children", []))

    new_jobs = []

    for lvl_idx, level_job_ids in enumerate(levels):
        pred_id = f"pegasus_runtime_predictor_L{lvl_idx}"

        new_jobs.append({
            "type": "job",
            "name": "pegasus-runtime-predictor",
            "id":   pred_id,
            "arguments": [
                str(Path(wf_yaml).resolve()),
                output_dir,
                f"--level={lvl_idx}",
            ],
            "uses": [],
            "profiles": {
                "pegasus": {
                    "job.type": "auxillary",
                    "label":    f"runtime-prediction-L{lvl_idx}",
                },
                "selector": {
                    "execution.site": "local",
                },
                "condor": {
                    "universe": "local",
                },
            },
        })

        # pred-LN → user jobs at level N
        dep_map.setdefault(pred_id, set()).update(level_job_ids)

        # user jobs at level N-1 → pred-LN
        if lvl_idx > 0:
            for pjid in levels[lvl_idx - 1]:
                dep_map.setdefault(pjid, set()).add(pred_id)

    # Serialise dep_map back to list-of-dicts
    new_deps = [{"id": pid, "children": sorted(cids)}
                for pid, cids in dep_map.items() if cids]

    wf["jobs"] = jobs + new_jobs
    wf[deps_key] = new_deps

    # ── Embed TC entry in the workflow YAML ───────────────────────────────
    tc = wf.get("transformationCatalog", {})
    transforms = tc.get("transformations", [])
    existing_names = {t.get("name") for t in transforms}
    if "pegasus-runtime-predictor" not in existing_names:
        transforms.append(_PRED_TC_ENTRY)
    tc["transformations"] = transforms
    wf["transformationCatalog"] = tc

    # Write temp workflow file
    orig = Path(wf_yaml).resolve()
    tmp_path = orig.parent / f"_pred_{orig.name}"
    with open(tmp_path, "w") as f:
        yaml.dump(wf, f, default_flow_style=False, sort_keys=False)

    # Write standalone TC as a fallback (more reliable than inline embedding)
    tmp_tc = _write_standalone_tc(orig.parent)

    return str(tmp_path), tmp_tc


def _read_property(key: str) -> str | None:
    """Read a single key from pegasus.properties in the current directory."""
    props_file = Path("pegasus.properties")
    if props_file.exists():
        for line in props_file.read_text().splitlines():
            line = line.strip()
            if line.startswith(key):
                return line.split("=", 1)[-1].strip()
    return None


def _model_path() -> str | None:
    """
    Resolve the model .pkl path.
    Priority: env var → pegasus.properties → default package location.
    Returns None if no model file is found anywhere.
    """
    # 1. Explicit env var
    env = os.environ.get("PEGASUS_RUNTIME_PREDICTION_MODEL")
    if env and Path(env).is_file():
        return env

    # 2. pegasus.properties key
    prop = _read_property("pegasus.runtime.prediction.model.path")
    if prop and Path(prop).is_file():
        return prop

    # 3. Default location: <repo>/packages/pegasus-python/src/Pegasus/models/
    default = (
        _SRC_DIR / "packages" / "pegasus-python"
        / "src" / "Pegasus" / "models" / "pegasus_oracle_model.pkl"
    )
    if default.is_file():
        return str(default)

    return None


def _prediction_enabled() -> bool:
    """
    Check pegasus.properties for pegasus.runtime.prediction.enable.
    Defaults to True. Set to 'false' to disable prediction job injection.
    Also respects PEGASUS_RUNTIME_PREDICTION=false env var.
    """
    if os.environ.get("PEGASUS_RUNTIME_PREDICTION", "").lower() in ("false", "0", "no"):
        return False
    val = _read_property("pegasus.runtime.prediction.enable")
    if val is not None:
        return val.lower() not in ("false", "0", "no")
    return True


# ── Main ──────────────────────────────────────────────────────────────────────

args    = sys.argv[1:]
wf_yaml = _find_workflow_yaml(args)
real    = _real_pegasus_plan()

tmp_wf = None
tmp_tc = None
plan_args = list(args)

if wf_yaml:
    model = _model_path()
    if not _prediction_enabled():
        print("[pegasus-plan] Runtime prediction disabled — skipping injection.", flush=True)
    elif model is None:
        print("[pegasus-plan] No model found — runtime prediction disabled. "
              "Train a model or set pegasus.runtime.prediction.model.path.", flush=True)
    else:
        tmp_wf, tmp_tc = _build_temp_workflow(wf_yaml)
        if tmp_wf:
            # Robust path replacement: resolve both sides before comparing
            wf_path = Path(wf_yaml).resolve()
            replaced = False
            plan_args = []
            for a in args:
                if not replaced and a.endswith((".yml", ".yaml")):
                    try:
                        if Path(a).resolve() == wf_path:
                            plan_args.append(tmp_wf)
                            replaced = True
                            continue
                    except Exception:
                        pass
                plan_args.append(a)
            if not replaced:
                # wf_yaml was found but comparison failed — substitute directly
                plan_args = [tmp_wf if a == wf_yaml else a for a in args]

            # Pass standalone TC file so Pegasus definitely sees our entry
            if tmp_tc:
                plan_args = [
                    f"-Dpegasus.catalog.transformation.file={tmp_tc}",
                ] + plan_args

            print(f"[pegasus-plan] Runtime prediction enabled (model: {model}) "
                  f"— injecting predictor jobs (tc: {tmp_tc}).", flush=True)
        else:
            print("[pegasus-plan] Could not build temp workflow — planning without prediction jobs.",
                  flush=True)

# Run real pegasus-plan (streams output directly — no capture needed)
result = subprocess.run([real] + plan_args)

# Clean up temp files
if tmp_wf and Path(tmp_wf).exists():
    Path(tmp_wf).unlink()
if tmp_tc and Path(tmp_tc).exists():
    Path(tmp_tc).unlink()

sys.exit(result.returncode)
